{
  "_comment": "Three synthetic Stripo module shapes used by 15-stripo-module-bindings.test.mjs. Each mirrors the output of saveStripoModuleToLibrary in stripo-modules.js — i.e. what ends up as a library entry after sync. The module HTML is embedded inline in the fixture for use by tests that bypass the filesystem.",

  "modules": [
    {
      "_case": "standard-smart-element",
      "_desc": "Module WITH registered_variables (p_title + p_description bindings) and matching esd-gen-* classes. This is the canonical Smart Element module shape.",
      "id": 1653410,
      "uid": "abc-uid-1653410",
      "name": "Hero Banner — Smart Element",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;p_title&quot;,&quot;defaultValue&quot;:&quot;Default Title&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-p-title&quot;,&quot;attribute&quot;:&quot;innerText&quot;}]},{&quot;variable&quot;:&quot;p_description&quot;,&quot;defaultValue&quot;:&quot;Default description copy.&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-p-description&quot;,&quot;attribute&quot;:&quot;innerText&quot;}]}]}\"><h1 class=\"esd-gen-p-title\" style=\"font-size:24px\">Default Title</h1><p class=\"esd-gen-p-description\" style=\"font-size:14px\">Default description copy.</p></div></td></tr></table>",
      "css": ".esd-gen-p-title { font-weight: bold; } .esd-gen-p-description { color: #333; }",

      "_expected": {
        "registered_variables": [
          {
            "name": "p_title",
            "blockMapping": [{ "selector": ".esd-gen-p-title", "attribute": "innerText" }]
          },
          {
            "name": "p_description",
            "blockMapping": [{ "selector": ".esd-gen-p-description", "attribute": "innerText" }]
          }
        ],
        "top_level_link_field": false,
        "esd_gen_classes": ["esd-gen-p-description", "esd-gen-p-title"],
        "likely_smart_container": false,
        "can_accept_in_values": ["p_title", "p_description"],
        "notes_should_not_contain": "No Smart Properties bindings detected"
      }
    },

    {
      "_case": "link-field-dead-end",
      "_desc": "Module with a top-level `link` field in esd-dynamic-block AND no proper CTA variable bindings in the variables array. This is the OG-preview dead-end case the probe documented — the wizard emits a top-level link when it crawls an anchor target, but the API silently ignores it at compose time.",
      "id": 1799900,
      "uid": "def-uid-1799900",
      "name": "Promo Card — CTA Dead-End",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;promo_title&quot;,&quot;defaultValue&quot;:&quot;Promo Title&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-promo-title&quot;,&quot;attribute&quot;:&quot;innerText&quot;}]}],&quot;link&quot;:{&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;a&quot;,&quot;attribute&quot;:&quot;href&quot;}]}}\"><h2 class=\"esd-gen-promo-title\">Promo Title</h2><a href=\"https://example.com/promo\" style=\"background:#000;color:#fff;padding:10px 20px\">Shop Now</a></div></td></tr></table>",
      "css": ".esd-gen-promo-title { font-size: 20px; }",

      "_expected": {
        "registered_variables": [
          {
            "name": "promo_title",
            "blockMapping": [{ "selector": ".esd-gen-promo-title", "attribute": "innerText" }]
          }
        ],
        "top_level_link_field": true,
        "esd_gen_classes": ["esd-gen-promo-title"],
        "likely_smart_container": false,
        "can_accept_in_values": ["promo_title"],
        "notes_should_contain": "Button CTA may be bound via the Smart Element wizard's top-level link field"
      }
    },

    {
      "_case": "naming-mismatch-with-orphans",
      "_desc": "Mirrors the live module 1653410 from production: Smart Properties registered with names that do NOT match their bound class basename (p_title bound to .esd-gen-title, not .esd-gen-p-title), AND a top-level link field, AND additional orphan esd-gen-* classes on the button that have no matching registered variable. This is the canary case for the 0.19.4 fix — under the old inferred-name cross-reference, ALL esd-gen classes (including the two properly bound ones) were flagged as unmapped. With the selector-based cross-reference, only the three orphan classes should be flagged.",
      "id": 1653411,
      "uid": "jkl-uid-1653411",
      "name": "Text + body + CTA",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;p_title&quot;,&quot;defaultValue&quot;:&quot;Default Title&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-title&quot;,&quot;attribute&quot;:&quot;&quot;}]},{&quot;variable&quot;:&quot;p_description&quot;,&quot;defaultValue&quot;:&quot;Default description.&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-description&quot;,&quot;attribute&quot;:&quot;&quot;}]}],&quot;link&quot;:{&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;a.esd-gen-Link&quot;,&quot;attribute&quot;:&quot;href&quot;}]}}\"><h1 class=\"esd-gen-title\">Default Title</h1><p class=\"esd-gen-description\">Default description.</p><a class=\"esd-gen-Link esd-gen-p-link\" href=\"https://example.com\"><span class=\"esd-gen-p-cta-text\">Click</span></a></div></td></tr></table>",
      "css": "",

      "_expected": {
        "registered_variables": [
          {
            "name": "p_title",
            "blockMapping": [{ "selector": ".esd-gen-title", "attribute": "" }]
          },
          {
            "name": "p_description",
            "blockMapping": [{ "selector": ".esd-gen-description", "attribute": "" }]
          }
        ],
        "top_level_link_field": true,
        "esd_gen_classes": ["esd-gen-Link", "esd-gen-description", "esd-gen-p-cta-text", "esd-gen-p-link", "esd-gen-title"],
        "likely_smart_container": false,
        "can_accept_in_values": ["p_title", "p_description"],
        "notes_should_contain": "Button CTA may be bound via the Smart Element wizard's top-level link field",
        "unmapped_classes_expected": ["esd-gen-Link", "esd-gen-p-cta-text", "esd-gen-p-link"],
        "unmapped_classes_must_not_include": ["esd-gen-title", "esd-gen-description"]
      }
    },

    {
      "_case": "selector-without-target",
      "_desc": "Module where a registered variable's selector (.esd-gen-image) does not exist on any element in the HTML. The esd_gen_classes list only contains esd-gen-cta, esd-gen-description, esd-gen-title. p_image should trigger a selector_without_target note. Mirrors the silent-no-op pattern in text+body+CTA style modules where the class hook was never added to the <img> element.",
      "id": 9001,
      "uid": "mno-uid-9001",
      "name": "Text + body + CTA — selector-without-target example",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;p_title&quot;,&quot;defaultValue&quot;:&quot;Default Title&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-title&quot;,&quot;attribute&quot;:&quot;&quot;}]},{&quot;variable&quot;:&quot;p_description&quot;,&quot;defaultValue&quot;:&quot;Default description.&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-description&quot;,&quot;attribute&quot;:&quot;&quot;}]},{&quot;variable&quot;:&quot;p_image&quot;,&quot;defaultValue&quot;:&quot;https://example.com/default.jpg&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-image&quot;,&quot;attribute&quot;:&quot;src&quot;}]}]}\"><h1 class=\"esd-gen-title\">Default Title</h1><p class=\"esd-gen-description\">Default description.</p><a class=\"esd-gen-cta\" href=\"https://example.com\">Click here</a></div></td></tr></table>",
      "css": "",

      "_expected": {
        "registered_variables": [
          {
            "name": "p_title",
            "blockMapping": [{ "selector": ".esd-gen-title", "attribute": "" }]
          },
          {
            "name": "p_description",
            "blockMapping": [{ "selector": ".esd-gen-description", "attribute": "" }]
          },
          {
            "name": "p_image",
            "blockMapping": [{ "selector": ".esd-gen-image", "attribute": "src" }]
          }
        ],
        "top_level_link_field": false,
        "esd_gen_classes": ["esd-gen-cta", "esd-gen-description", "esd-gen-title"],
        "likely_smart_container": false,
        "can_accept_in_values": ["p_title", "p_description", "p_image"],
        "selector_without_target_variable": "p_image",
        "selector_without_target_selector": ".esd-gen-image"
      }
    },

