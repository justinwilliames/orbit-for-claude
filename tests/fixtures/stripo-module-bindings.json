    {
      "_case": "href-outer-wrapping-text-inner",
      "_desc": "Module where an outer <a class=\"esd-gen-link\"> binds via attribute=href (NOT text-replacing) wrapping an inner <span class=\"esd-gen-cta-text\"> bound via empty attribute (text-replacing). After Item-2's attribute-kind filter, this must NOT fire the nesting-hazard note — href writes don't clobber inner children. This mirrors the standard Stripo button pattern where the link URL is one binding and the button label text is another.",
      "id": 9005,
      "uid": "yza-uid-9005",
      "name": "Button — href wrapping text (safe pattern)",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;p_cta_link&quot;,&quot;defaultValue&quot;:&quot;https://example.com/cta&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-link&quot;,&quot;attribute&quot;:&quot;href&quot;}]},{&quot;variable&quot;:&quot;p_cta_text&quot;,&quot;defaultValue&quot;:&quot;Click here&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-cta-text&quot;,&quot;attribute&quot;:&quot;&quot;}]}]}\"><a class=\"esd-gen-link\" href=\"https://example.com/cta\"><span class=\"esd-gen-cta-text\">Click here</span></a></div></td></tr></table>",
      "css": "",

      "_expected": {
        "top_level_link_field": false,
        "likely_smart_container": false,
        "nesting_hazard_should_not_fire": true
      }
    },

    {
      "_case": "deeply-nested-only-one-registered",
