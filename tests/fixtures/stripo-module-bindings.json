    {
      "_case": "link-field-dead-end",
      "_desc": "Module with a top-level `link` field in esd-dynamic-block AND no proper CTA variable bindings in the variables array. This is the OG-preview dead-end case the probe documented — the wizard emits a top-level link when it crawls an anchor target, but the API silently ignores it at compose time.",
      "id": 1799900,
      "uid": "def-uid-1799900",
      "name": "Promo Card — CTA Dead-End",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;promo_title&quot;,&quot;defaultValue&quot;:&quot;Promo Title&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-promo-title&quot;,&quot;attribute&quot;:&quot;innerText&quot;}]}],&quot;link&quot;:{&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;a&quot;,&quot;attribute&quot;:&quot;href&quot;}]}}\"><h2 class=\"esd-gen-promo-title\">Promo Title</h2><a href=\"https://example.com/promo\" style=\"background:#000;color:#fff;padding:10px 20px\">Shop Now</a></div></td></tr></table>",
      "css": ".esd-gen-promo-title { font-size: 20px; }",

      "_expected": {
        "registered_variables": [
          {
            "name": "promo_title",
            "blockMapping": [{ "selector": ".esd-gen-promo-title", "attribute": "innerText" }]
          }
        ],
        "top_level_link_field": true,
        "esd_gen_classes": ["esd-gen-promo-title"],
        "likely_smart_container": false,
        "can_accept_in_values": ["promo_title"],
        "notes_should_contain": "Button CTA may be bound via the Smart Element wizard's top-level link field"
      }
    },

    {
      "_case": "naming-mismatch-with-orphans",
      "_desc": "Mirrors the live module 1653410 from production: Smart Properties registered with names that do NOT match their bound class basename (p_title bound to .esd-gen-title, not .esd-gen-p-title), AND a top-level link field, AND additional orphan esd-gen-* classes on the button that have no matching registered variable. This is the canary case for the 0.19.4 fix — under the old inferred-name cross-reference, ALL esd-gen classes (including the two properly bound ones) were flagged as unmapped. With the selector-based cross-reference, only the three orphan classes should be flagged.",
      "id": 1653411,
      "uid": "jkl-uid-1653411",
