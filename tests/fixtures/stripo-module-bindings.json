    {
      "_case": "three-unique-dynamic-images",
      "_desc": "Module with 3 p_image* variables — each with a UNIQUE defaultValue URL, suggesting legitimately dynamic product images. After the Item-1 tightening, the static-asset pattern note must NOT fire even though the count threshold (≥3 image-bound vars) is met. Mirrors a product-grid or recommendation module where the images are real product photography rather than canonical tick/cross markers.",
      "id": 9003,
      "uid": "stu-uid-9003",
      "name": "Product grid — three unique dynamic images",
      "markup": "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-collapse:collapse\"><tr><td class=\"esd-structure\" style=\"padding:20px\"><div esd-dynamic-block=\"{&quot;variables&quot;:[{&quot;variable&quot;:&quot;p_image&quot;,&quot;defaultValue&quot;:&quot;https://example.com/product-a.jpg&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-image&quot;,&quot;attribute&quot;:&quot;src&quot;}]},{&quot;variable&quot;:&quot;p_image2&quot;,&quot;defaultValue&quot;:&quot;https://example.com/product-b.jpg&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-image2&quot;,&quot;attribute&quot;:&quot;src&quot;}]},{&quot;variable&quot;:&quot;p_image3&quot;,&quot;defaultValue&quot;:&quot;https://example.com/product-c.jpg&quot;,&quot;blockMapping&quot;:[{&quot;selector&quot;:&quot;.esd-gen-image3&quot;,&quot;attribute&quot;:&quot;src&quot;}]}]}\"><img class=\"esd-gen-image\" src=\"https://example.com/product-a.jpg\" /><img class=\"esd-gen-image2\" src=\"https://example.com/product-b.jpg\" /><img class=\"esd-gen-image3\" src=\"https://example.com/product-c.jpg\" /></div></td></tr></table>",
      "css": "",

      "_expected": {
        "top_level_link_field": false,
        "likely_smart_container": false,
        "image_variable_names": ["p_image", "p_image2", "p_image3"],
        "static_asset_note_should_not_fire": true
      }
    },

