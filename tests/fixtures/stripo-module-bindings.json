      "css": ".esd-gen-promo-title { font-size: 20px; }",
      "_expected": {
        "registered_variables": [
          {
            "name": "promo_title",
            "blockMapping": [
              {
                "selector": ".esd-gen-promo-title",
                "attribute": "innerText"
